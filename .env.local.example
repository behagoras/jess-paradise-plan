# Clerk — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Convex — run `npx convex dev` to populate these
NEXT_PUBLIC_CONVEX_URL=https://xxx.convex.cloud

# The Clerk JWT issuer domain, used by convex/auth.config.ts
# Found in Clerk dashboard → JWT Templates → "convex"
NEXT_PUBLIC_CLERK_FRONTEND_API_URL=https://xxx.clerk.accounts.dev
