# Clerk — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Convex — run `npx convex dev` to populate these
NEXT_PUBLIC_CONVEX_URL=https://xxx.convex.cloud

# The Clerk JWT issuer domain, used by convex/auth.config.ts
# Found in Clerk dashboard → JWT Templates → "convex"
NEXT_PUBLIC_CLERK_FRONTEND_API_URL=https://xxx.clerk.accounts.dev

# Travelpayouts — https://app.travelpayouts.com
# Your account id, used as the affiliate marker in the hand-off deep link
# (Dashboard → bottom-left, "ID …"). Public attribution id — safe to ship.
NEXT_PUBLIC_TP_MARKER=742129
# Optional: Travelpayouts "Drive" tracking script src (Dashboard → Drive →
# Install manually). Leave unset to skip loading Drive.
NEXT_PUBLIC_TP_DRIVE_SRC=https://emrld.ltd/NTQyMDg5.js?t=542089
# Travelpayouts API token for LIVE flight/hotel data — SECRET, server-side only.
# Do NOT prefix with NEXT_PUBLIC and never ship it in the client bundle.
#
# IMPORTANT: TRAVELPAYOUTS_API_KEY (this file, for local scripts/curl) and the
# Convex deployment env var TRAVELPAYOUTS_TOKEN are the SAME token value. The
# Convex actions read `process.env.TRAVELPAYOUTS_TOKEN ?? TRAVELPAYOUTS_API_KEY`,
# but in production the token MUST live in the Convex deployment env (never in
# Vercel / the client). Set it once with:
#   npx convex env set TRAVELPAYOUTS_TOKEN "<same value as TRAVELPAYOUTS_API_KEY>"
# Verify with: npx convex env list
TRAVELPAYOUTS_API_KEY=your-travelpayouts-token
